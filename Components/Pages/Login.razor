@page "/login"
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Login_PageTitle"]</PageTitle>

<div class="row">
    <div class="col-md-6 col-md-offset-3">
        <div class="panel panel-default">
            <div class="panel-heading"><h3 class="panel-title">@L["Login_SignIn"]</h3></div>
            <div class="panel-body">
                @if (showError)
                {
                    <div class="alert alert-danger">@L["Login_Invalid"]</div>
                }
                <form action="/account/login" method="post" data-enhance="false">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnurl" value="@returnUrl" />
                    <div class="form-group">
                        <label for="username">@L["Login_Username"]</label>
                        <input id="username" name="username" class="form-control" autocomplete="username" required />
                    </div>
                    <div class="form-group">
                        <label for="password">@L["Login_Password"]</label>
                        <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" required />
                    </div>
                    <button type="submit" class="btn btn-primary">@L["Login_SignIn"]</button>
                </form>
            </div>
        </div>
        <p class="text-muted small">@L["Login_NoReg"]</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ReturnUrl")] public string? ReturnUrlQuery { get; set; }

    private bool showError => Error == "1";
    private string returnUrl => string.IsNullOrEmpty(ReturnUrlQuery) ? "" : ReturnUrlQuery;
}
