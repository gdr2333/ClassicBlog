@page "/login"
@inject NavigationManager Nav

<PageTitle>Sign in — ClassicBlog</PageTitle>

<div class="row">
    <div class="col-md-6 col-md-offset-3">
        <div class="panel panel-default">
            <div class="panel-heading"><h3 class="panel-title">Sign in</h3></div>
            <div class="panel-body">
                @if (showError)
                {
                    <div class="alert alert-danger">Invalid username or password.</div>
                }
                <form action="/account/login" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="returnurl" value="@returnUrl" />
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input id="username" name="username" class="form-control" autocomplete="username" required />
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" required />
                    </div>
                    <button type="submit" class="btn btn-primary">Sign in</button>
                </form>
            </div>
        </div>
        <p class="text-muted small">Accounts are created by an administrator; there is no self-registration.</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery(Name = "ReturnUrl")] public string? ReturnUrlQuery { get; set; }

    private bool showError => Error == "1";
    private string returnUrl => string.IsNullOrEmpty(ReturnUrlQuery) ? "" : ReturnUrlQuery;
}
