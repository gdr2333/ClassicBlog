@page "/account/change-password"
@attribute [Authorize]
@inject AccountService Accounts
@inject AuthenticationStateProvider AuthState
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["ChangePwd_PageTitle"]</PageTitle>

<div class="page-header">
    <h1>@L["ChangePwd_Heading"]</h1>
</div>

@if (currentUser is null)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div class="col-md-6">
        @if (message is not null)
        {
            <div class="alert @(success ? "alert-success" : "alert-danger")">@message</div>
        }

        <EditForm Model="form" OnValidSubmit="ChangeAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="current">@L["ChangePwd_Current"]</label>
                <InputText id="current" type="password" class="form-control" @bind-Value="form.CurrentPassword" />
                <ValidationMessage For="@(() => form.CurrentPassword)" />
            </div>

            <div class="form-group">
                <label for="new">@L["ChangePwd_New"]</label>
                <InputText id="new" type="password" class="form-control" @bind-Value="form.NewPassword" />
                <ValidationMessage For="@(() => form.NewPassword)" />
            </div>

            <div class="form-group">
                <label for="confirm">@L["ChangePwd_Confirm"]</label>
                <InputText id="confirm" type="password" class="form-control" @bind-Value="form.ConfirmPassword" />
                <ValidationMessage For="@(() => form.ConfirmPassword)" />
            </div>

            <button type="submit" class="btn btn-primary">@L["ChangePwd_Update"]</button>
        </EditForm>
    </div>
}

@code {
    private ApplicationUser? currentUser;
    private ChangePasswordForm form = new();
    private string? message;
    private bool success;

    protected override async Task OnInitializedAsync()
    {
        var name = (await AuthState.GetAuthenticationStateAsync()).User.Identity?.Name;
        if (name is not null)
            currentUser = await Accounts.FindByNameAsync(name);
    }

    private async Task ChangeAsync()
    {
        if (currentUser is null) return;

        success = await Accounts.ChangePasswordAsync(currentUser.Id, form.CurrentPassword, form.NewPassword);
        message = success ? L["ChangePwd_Success"] : L["ChangePwd_Wrong"];
        if (success)
            form = new ChangePasswordForm();
    }

    private class ChangePasswordForm
    {
        [Required] public string CurrentPassword { get; set; } = string.Empty;
        [Required, MinLength(6)] public string NewPassword { get; set; } = string.Empty;
        [Required, Compare(nameof(NewPassword))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
