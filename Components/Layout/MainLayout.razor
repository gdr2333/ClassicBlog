@inherits LayoutComponentBase

<NavMenu />

<div class="container">
    <div class="row">
        <div class="col-md-9">
            @Body
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-heading">About</div>
                <div class="panel-body">
                    <p>A demo blog built with Blazor Server, EF Core + SQLite, and the BOOTSTRA.386 theme.</p>
                </div>
            </div>
        </div>
    </div>

    <hr />
    <footer>
        <p class="text-muted">&copy; @DateTime.Now.Year ClassicBlog &mdash; skinned with BOOTSTRA.386</p>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <span class="dismiss">Dismiss</span>
</div>
